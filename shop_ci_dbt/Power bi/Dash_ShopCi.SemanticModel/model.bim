        "lineageTag": "e640ecbe-a396-4a78-838a-b37e6f4ac51a",
        "measures": [
          {
            "name": "ca_brut",
            "expression": "SUM(fait_ventes[montant_ligne])",
            "formatString": "0",
            "lineageTag": "c9d3845b-eb45-4d60-a131-e3b352eb2f8e"
          },
          {
            "name": "ca_officiel",
            "expression": [
              "",
              "CALCULATE(",
              "    SUM(fait_ventes[montant_ligne]),",
              "    fait_ventes[statut] <> \"annulee\",",
              "    fait_ventes[statut] <> \"retournee\"",
              ")"
            ],
            "formatString": "#,0",
            "lineageTag": "2093da52-0d10-4058-8d03-494ef9753cc9"
          },
          {
            "name": "marge",
            "expression": [
              "",
              "CALCULATE(",
              "    SUM(fait_ventes[marge_ligne]),",
              "    fait_ventes[statut] <> \"annulee\",",
              "    fait_ventes[statut] <> \"retournee\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "daee65e9-ac74-439c-91a5-34923f19bed5"
          },
          {
            "name": "taux_marge",
            "expression": "DIVIDE([marge], [ca_officiel], 0)",
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "df8e8ede-cb41-473f-8a32-8f9066437342"
          },
          {
            "name": "nb_commandes_officiel",
            "expression": [
              "",
              "CALCULATE(",
              "    DISTINCTCOUNT(fait_ventes[id_commande]),",
              "    fait_ventes[statut] <> \"annulee\",",
              "    fait_ventes[statut] <> \"retournee\"",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "720dcc67-0112-4601-9490-d912eac2d3fd"
          },
          {
            "name": "panier_moyen",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": "DIVIDE([ca_officiel], [nb_commandes_officiel], 0)",
            "lineageTag": "92735745-42f3-4dc8-9a7f-5e5ae32b584e"
          }
        ],
        "partitions": [
